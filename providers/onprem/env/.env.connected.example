# On-prem CONNECTED mode environment template.
# Copy to .env and fill in values. Treat as secret — do not commit.

# --------- Identity ---------
ENVIRONMENT=production
PROJECT_NAME=axiome
FQDN=axiome.customer.example.com

# --------- Image registry ---------
# ECR (recommended): pull from your AWS-hosted images. Requires AWS credentials below.
# Alternative: Harbor / GHCR / private Docker Hub
REGISTRY_URL=123456789012.dkr.ecr.eu-west-3.amazonaws.com
BACKEND_IMAGE_TAG=stable
BIOCOMPUTE_IMAGE_TAG=stable
FRONTEND_IMAGE_TAG=stable

# AWS credentials (only needed if pulling from ECR)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3

# --------- Database (managed external services) ---------
DATABASE_URL=postgresql://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/axiome?sslmode=require
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/axiome?retryWrites=true&w=majority

# --------- Object storage ---------
# AWS S3
S3_REGION=eu-west-3
S3_BUCKET_ARTIFACTS=axiome-onprem-customer-artifacts
S3_BUCKET_UPLOADS=axiome-onprem-customer-uploads
S3_BUCKET_SYSTEM=axiome-onprem-customer-system
# S3 endpoint left blank for AWS S3; set for Scaleway/MinIO
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# --------- App secrets ---------
JWT_SECRET=  # Generate: openssl rand -base64 64
