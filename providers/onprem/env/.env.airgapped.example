# On-prem AIR-GAPPED mode environment template.
# Copy to .env and fill in values. Treat as secret — do not commit.
#
# Air-gapped mode runs ALL state locally: Postgres, MongoDB, MinIO. The customer
# is responsible for backups, HA, and upgrades. Image distribution is via tarball
# preloaded at install time (see scripts/load-images.sh).

# --------- Identity ---------
ENVIRONMENT=production
PROJECT_NAME=axiome
FQDN=axiome.local

# --------- Image registry ---------
# Air-gapped: REGISTRY_URL is unused at runtime; images are loaded from tarball.
# Set to whatever the images were tagged as during preload.
REGISTRY_URL=axiome
BACKEND_IMAGE_TAG=stable
BIOCOMPUTE_IMAGE_TAG=stable
FRONTEND_IMAGE_TAG=stable

# --------- Database (self-hosted on this box) ---------
POSTGRES_DB=axiome
POSTGRES_USER=axiome
POSTGRES_PASSWORD=  # Generate: openssl rand -base64 32

MONGODB_DB=axiome
MONGODB_USER=axiome
MONGODB_PASSWORD=   # Generate: openssl rand -base64 32

# --------- Object storage (MinIO on this box) ---------
S3_ACCESS_KEY=axiome-minio  # Generate or use random ID
S3_SECRET_KEY=              # Generate: openssl rand -base64 32
S3_REGION=us-east-1
S3_BUCKET_ARTIFACTS=axiome-artifacts
S3_BUCKET_UPLOADS=axiome-uploads
S3_BUCKET_SYSTEM=axiome-system

# --------- App secrets ---------
JWT_SECRET=  # Generate: openssl rand -base64 64
