# Axiome Local Development Environment
# Copy this file to .env.local and fill in values

# Database — Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=axiome
POSTGRES_USER=axiome
POSTGRES_PASSWORD=axiome_local_dev

# Database — MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=axiome
MONGODB_USER=axiome
MONGODB_PASSWORD=axiome_local_dev

# Object Storage — MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_ARTIFACTS=axiome-local-artifacts
S3_BUCKET_UPLOADS=axiome-local-uploads
S3_BUCKET_SYSTEM=axiome-local-system
S3_REGION=us-east-1

# Message Broker — RabbitMQ
RABBITMQ_USER=axiome
RABBITMQ_PASSWORD=axiome_local_dev
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Cache / WebSocket adapter — Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=3000
NODE_ENV=development
JWT_SECRET=local-dev-jwt-secret-change-in-production
SESSION_SECRET=local-dev-session-secret-change-in-production

# Local bootstrap admin (leave blank in prod to disable auto-seeding)
BOOTSTRAP_ADMIN_EMAIL=admin@axiome.local
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_FIRST_NAME=Local
BOOTSTRAP_ADMIN_LAST_NAME=Admin

# Biocompute
BIOCOMPUTE_PORT=8000
BIOCOMPUTE_URL=http://localhost:8000
PYTHON_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# Observability (optional)
# SENTRY_DSN=
# LOG_LEVEL=debug
